{
  "name": "notes-monorepo",
  "private": true,
  "version": "0.0.0",
  "scripts": {
    "dev:api": "pnpm --filter @notes/api dev",
    "dev:web": "pnpm --filter @notes/web dev",
    "build": "pnpm -r build",
    "typecheck": "pnpm -r typecheck",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "devDependencies": {
    "@vitest/coverage-v8": "^4.0.18",
    "typescript": "^5.7.3",
    "vitest": "^4.0.18"
  },
  "pnpm": {
    "allowedDeprecatedVersions": {},
    "onlyBuiltDependencies": [
      "better-sqlite3",
      "esbuild"
    ]
  }
}
